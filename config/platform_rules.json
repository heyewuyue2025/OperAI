{
  "weibo": {
    "max_chars": 140,
    "tone": "短句、话题标签、互动导向",
    "avoid": ["长外链堆砌", "未经证实的承诺"]
  },
  "wechat": {
    "max_chars": 2000,
    "tone": "叙事段落、信息密度、可转发",
    "avoid": ["标题党", "诱导分享话术过度"]
  },
  "xhs": {
    "max_chars": 1000,
    "tone": "场景化、适度 emoji、种草但不夸大",
    "avoid": ["医疗功效宣称", "绝对化用词"]
  }
}
