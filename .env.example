# Copy this file to .env before running locally.
# Leave OPENAI_API_KEY empty to use mock / rule-first demo mode.

OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.deepseek.com
OPENAI_MODEL=deepseek-v4-pro

# 1 = force local mock mode, useful for offline demo or screen recording.
OPERAI_MOCK=

# Optional brand homepage URL.
# BRAND_HOME_URL=http://127.0.0.1:8080

